{
  "name": "starter-cloudflare",
  "type": "module",
  "module": "src/worker.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "vp dev",
    "test": "vp test",
    "test:browser": "vp test --project browser",
    "test:unit": "vp test --project unit",
    "test:worker": "vp test --project worker",
    "test:integration": "vp test --project integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:mutate": "stryker run",
    "build": "vp build",
    "preview": "vp preview",
    "typegen": "wrangler types",
    "lint": "vp check --fix",
    "format": "vp fmt",
    "ci": "vp check && knip",
    "knip": "DATABASE_URL=postgres://knip:knip@localhost:5432/knip knip",
    "fix": "vp check --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "agents": "^0.6.0",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.3",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.11.0",
    "reshaped": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.17.1",
    "@csstools/postcss-global-data": "^4.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.51.0",
    "@react-router/dev": "^7.11.0",
    "@react-router/fs-routes": "^7.11.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@testcontainers/postgresql": "^11.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "cssnano": "^7.1.3",
    "drizzle-kit": "^0.31.8",
    "happy-dom": "^20.0.11",
    "jiti": "^2.6.1",
    "knip": "^5.80.2",
    "postcss-custom-media": "^12.0.1",
    "testcontainers": "^11.11.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vitest-browser-react": "^2.0.2",
    "wrangler": "^4.54.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
