{
  "name": "starter",
  "type": "module",
  "module": "src/server.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "vite dev",
    "test": "vitest",
    "test:browser": "vitest --project browser",
    "test:unit": "vitest --project unit",
    "test:integration": "vitest --project integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:mutate": "stryker run",
    "build": "vite build",
    "preview": "vite preview",
    "typegen": "wrangler types",
    "lint": "oxlint --fix",
    "format": "oxfmt --write .",
    "typecheck:domain": "tsc --noEmit -p tsconfig.domain.json",
    "typecheck:infra": "tsc --noEmit -p tsconfig.infra.json",
    "typecheck:layers": "tsc --noEmit -p tsconfig.domain.json && tsc --noEmit -p tsconfig.infra.json",
    "fallow": "fallow",
    "fallow:ci": "fallow audit",
    "ci": "oxlint && oxfmt --check . && pnpm typecheck:layers && pnpm fallow:ci",
    "fix": "oxlint --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@chakra-ui/charts": "^3.34.0",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@tanstack/react-router": "^1.114.3",
    "@tanstack/react-start": "^1.166.18",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.51.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@testcontainers/postgresql": "^11.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "acorn": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "fallow": "^2.48.1",
    "happy-dom": "^20.0.11",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.6",
    "msw": "^2.13.6",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "testcontainers": "^11.11.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0",
    "wrangler": "^4.76.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.32.1"
}
